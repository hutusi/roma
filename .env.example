# Neon Postgres — pooled connection string, used by the app at runtime
DATABASE_URL=

# Neon Postgres — direct (unpooled) connection string, used only by
# drizzle-kit migrations
DATABASE_URL_UNPOOLED=

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Vercel Blob read/write token (stills, posters, portraits)
BLOB_READ_WRITE_TOKEN=

# Optional, M5+: transactional email + TMDB metadata import
# RESEND_API_KEY=
# TMDB_API_TOKEN=
