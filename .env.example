# Neon Postgres — pooled connection string, used by the app at runtime
DATABASE_URL=

# Neon Postgres — direct (unpooled) connection string, used only by
# drizzle-kit migrations
DATABASE_URL_UNPOOLED=

# better-auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Vercel Blob read/write token (stills, posters, portraits)
BLOB_READ_WRITE_TOKEN=

# Optional, M5+: transactional email + TMDB metadata import
# RESEND_API_KEY=
# TMDB_API_TOKEN=

# canonical origin for metadata/sitemap/OG (defaults to https://babuban.com)
# NEXT_PUBLIC_SITE_URL=
# transactional email sender, e.g. 八部半 <noreply@babuban.com>
# EMAIL_FROM=

# Optional, production only: search-console ownership meta tags
# (baked into the SSG HTML — redeploy after changing)
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=
# BAIDU_SITE_VERIFICATION=

# Optional, production only: IndexNow ping on publish (Bing et al.)
# generate with: openssl rand -hex 16; leave unset to disable
# INDEXNOW_KEY=
